# Copy to src/.env and fill in values. Dotenv loads from src/.env (see src/config/index.js).

MONGODB_URI=mongodb://127.0.0.1:27017/your-database

# Required for signup/login — without these you get "JWT secrets are not configured"
JWT_SECRET=use-a-long-random-string-at-least-32-chars
# Optional; defaults to JWT_SECRET if omitted
# JWT_REFRESH_SECRET=another-long-random-string

# Auth cookies (httpOnly): SameSite/Secure for cross-origin frontends
# COOKIE_SAME_SITE=lax|strict|none   # production defaults to none (needs HTTPS)
# COOKIE_SECURE=true|false           # default true in production or when SameSite=none
# JWT_ACCESS_COOKIE_MAX_AGE_MS=     # default 72000000 (20h)
# JWT_REFRESH_COOKIE_MAX_AGE_MS=    # default 604800000 (7d)

# Optional Redis cache for product list
# REDIS_URL=redis://127.0.0.1:6379
# PRODUCTS_CACHE_TTL_SECONDS=300
